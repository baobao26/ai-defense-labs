{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-prereqs.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-sensitive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/validate-rule.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/notify-complete.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(./.env*)",
      "Read(./*.key)",
      "Read(./*.pem)",
      "Read(./secrets/**)",
      "Edit(./.env*)",
      "Edit(./*.key)",
      "Edit(./*.pem)",
      "Edit(./secrets/**)"
    ],
    "allow": [
      "Bash(npm test)",
      "Bash(python -m pytest)"
    ]
  }
}
